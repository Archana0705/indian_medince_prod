QUERY:  SELECT DISTINCT
        s.sno AS smo,
        s.medicine_name,
        s.packing_size,
        ROUND(s.amount, 2) AS amount,
        s.indented_quantity,
        s.godown_stock_availablity,
        s.supply_quantity,
        ROUND(s.supply_price, 2) AS supply_price,
        s.percentage_of_despatch_quantity,
        s.balance_quantity_to_be_supplied,
        s.remarks,
        s.received_quantity,
        s.price,
        n.name_of_the_institution,
        n.quarters,
        n.financial_year,
        n.name_of_the_district,
        n.system,
        n.institution_type
    FROM 
        despatch_medicine s
    JOIN indent_medicine_details n ON s.dno = n.sno
    JOIN im_medicine med ON n.medicine_name = med.name_of_the_medicine
    WHERE 
        med.medicine_by = 'Factory'
        AND (p_institution IS NULL OR n.name_of_the_institution = p_institution)
        AND (p_district IS NULL OR n.name_of_the_district = p_district)
        AND (p_financial IS NULL OR n.financial_year = p_financial)
        AND (p_quarters IS NULL OR n.quarters = p_quarters)
